FROM node:20-alpine

WORKDIR /app/frontend

# Copy package files
COPY package*.json ../
COPY frontend/package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY frontend ./
COPY shared ../shared

EXPOSE 5173

# Health check - Vite dev server
HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=3 \
    CMD wget -q -O- http://localhost:5173 || exit 1

# Run Vite dev server with host binding (visible outside container)
CMD ["npm", "run", "dev"]
