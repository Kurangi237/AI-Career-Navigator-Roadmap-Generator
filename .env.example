# ============================================
# SUPABASE DATABASE CONFIGURATION
# ============================================
# Required for database persistence (user profiles, roadmaps, resumes, etc.)
#
# Steps to set up:
# 1. Go to https://supabase.com and create a free project
# 2. In project Settings → API, copy your Project URL and Anon Key
# 3. Paste the values below
#
# See SUPABASE_SETUP.md for detailed instructions
#
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Backend Supabase (for server-side operations)
# Get Service Role Key from Settings → API (bottom of page, KEEP SECRET!)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# GEMINI AI API (for roadmap, resume, chat)
# ============================================
# Get from https://makersuite.google.com/app/apikeys
GENAI_API_KEY=your_google_gemini_api_key

# ============================================
# API CONFIGURATION
# ============================================
# Frontend points to backend API
VITE_API_BASE_URL=http://localhost:3004

# Backend API port
JUDGE_API_BASE=http://localhost:3004

# ============================================
# STRIPE BILLING (Optional - for payments)
# ============================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx
APP_BASE_URL=http://localhost:3000

# ============================================
# CODE JUDGE CONFIGURATION (Optional)
# ============================================
# false -> uses local system compilers
# true  -> uses Docker containers
JUDGE_USE_DOCKER=false
JUDGE_WORKER_TOKEN=local-worker-token

# ============================================
# LOCAL SETUP INSTRUCTIONS
# ============================================
# 1. Copy this file to .env.local
# 2. Fill in your actual values
# 3. Restart dev server: npm run dev:all
# 4. See SUPABASE_SETUP.md for complete guide

