# Optional: configure Supabase to persist notifications centrally
# Create a free project on https://supabase.com, then set these values.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# After setting, restart the dev server: npm run dev

# Required for backend chat/AI endpoints (local + production)
GENAI_API_KEY=your_google_gemini_api_key

# Optional: if frontend and API are on different hosts, point frontend to API origin.
# Example: http://localhost:3004 or https://your-api-domain.com
VITE_API_BASE_URL=http://localhost:3004

# Judge execution mode:
# false -> uses local system compilers (python/javac/gcc/g++)
# true  -> uses Docker containers for sandboxed execution
JUDGE_USE_DOCKER=false
JUDGE_WORKER_TOKEN=local-worker-token
JUDGE_API_BASE=http://localhost:3004

# Stripe billing (required for checkout + webhook sync)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx
APP_BASE_URL=http://localhost:3000

# Supabase service role for webhook-side subscription sync (server-only, never in frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Copy this file to .env.local and populate real secrets locally only.
