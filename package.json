{
  "name": "AI-Career-Navigator-Roadmap-Generator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cd frontend && vite",
    "dev:api": "node backend/dev-mock-server.mjs",
    "dev:runner": "node backend/runner/secure-runner.mjs",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev\"",
    "dev:full": "vercel dev",
    "build": "cd frontend && vite build",
    "preview": "cd frontend && vite preview",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@google/genai": "^1.33.0",
    "@monaco-editor/react": "^4.7.0",
    "@supabase/supabase-js": "^2.24.0",
    "@types/express": "^5.0.6",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.8.2",
    "vercel": "^50.22.0",
    "vite": "^6.2.0"
  }
