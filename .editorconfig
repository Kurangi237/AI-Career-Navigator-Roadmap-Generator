# EditorConfig for project-wide settings
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{sql,pgsql}]
# PostgreSQL dialect - do not use MSSQL linter
indent_size = 2
sql_dialect = postgres

[*.json]
indent_size = 2

[*.ts,*.tsx,*.js,*.jsx]
indent_size = 2
